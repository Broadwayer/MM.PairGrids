<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MM.PairGrids">


    <Style TargetType="{x:Type local:SimplePairGrid}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SimplePairGrid}">
                    <Border 
                            BorderBrush="DarkSeaGreen"
                            BorderThickness="2">

                        <Grid IsSharedSizeScope="True" Cursor="">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition SharedSizeGroup="NameColumn"
                                                  Width="{Binding ColumnNameWidth,
                                RelativeSource={RelativeSource TemplatedParent}, 
                                Mode=TwoWay}"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- GridSplitter for changing column widths -->
                            <GridSplitter x:Name="PART_Splitter" Grid.Column="1" Width="5" Background="Gray" HorizontalAlignment="Stretch" ShowsPreview="False" Cursor="SizeWE"/>

                            <ItemsControl x:Name="PART_ItemsControl" Grid.ColumnSpan="3" ItemsSource="{TemplateBinding ItemsSource}"
                                VirtualizingStackPanel.IsVirtualizing="False"
                                ItemTemplate="{DynamicResource ValueHolderItemTemplate}" 
                                Cursor="" Visibility="{TemplateBinding Visibility}">
                            </ItemsControl>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>